@model WaitingListConfirmationViewModel

@{
    ViewData["Title"] = "You're on the list";
}

<div class="mx-auto max-w-2xl space-y-6">
    <section class="space-y-3 rounded border p-6 shadow-sm">
        <h1 class="text-3xl font-bold">You're on the list</h1>
        <p class="text-gray-600">
            Thanks, <strong>@Model.Name</strong>. We’ll keep you posted at <strong>@Model.Email</strong>.
        </p>

        <dl class="grid gap-3 sm:grid-cols-2">
            <div>
                <dt class="text-sm font-medium text-gray-500">Queue position</dt>
                <dd class="text-lg">@Model.QueuePosition</dd>
            </div>
            <div>
                <dt class="text-sm font-medium text-gray-500">Submitted at</dt>
                <dd class="text-lg">@Model.SubmittedAt.UtcDateTime.ToLocalTime()</dd>
            </div>
        </dl>
    </section>

    <a asp-action="Index" class="text-blue-600 underline">Back to sign-up form</a>
</div>

